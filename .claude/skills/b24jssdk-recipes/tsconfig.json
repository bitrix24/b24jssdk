{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "examples/*.ts",
    "types/external.d.ts"
  ]
}
